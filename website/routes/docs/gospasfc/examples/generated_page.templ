  var query = $state("")
  var items = []string{"Apple", "Banana", "Cherry", "Date"}
</script>

<script lang="ts">
  import { $derived } from "@gospa/runtime"
  
  const filtered = $derived(() => {
    const q = query.toLowerCase().trim()
    if (!q) return items
    return items.filter((item) => item.toLowerCase().includes(q))
  })
</script>

<template>
  <div class="search-box">
    <input on:input={func(e *gospa.Event) { query = e.Value }} placeholder="Search..." />
    <ul>
      {for _, item := range filtered.get()}
