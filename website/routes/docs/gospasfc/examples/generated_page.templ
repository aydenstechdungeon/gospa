  import { onMount } from "@gospa/runtime"
  
  const data = [10, 20, 30]
  
  onMount(() => {
    // Initialize Chart.js on client after hydration.
    const canvas = document.getElementById("myChart") as HTMLCanvasElement | null
    if (!canvas) return
    const ctx = canvas.getContext("2d")
    if (!ctx) return
    
    new Chart(ctx, {
      type: "bar",
