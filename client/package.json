{
  "name": "@gospa/client",
  "version": "0.1.14",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "bun typecheck",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "rm -f ./dist/*.js ./dist/*.js.gz ./dist/*.js.br && bun build ./src/runtime.ts ./src/runtime-core.ts ./src/runtime-micro.ts --outdir ./dist --target browser --minify --splitting --format esm --define \"GOSPA_DEBUG=false\"",
    "compress": "find ./dist -name '*.js' -exec gzip -k -f -9 {} \\; && find ./dist -name '*.js' -exec brotli -k -f -9 {} \\;",
    "build:embed": "bun run build && bun run compress && cp -r ./dist/* ../embed/",
    "build:empty": "rm -f ../embed/*.js && bun run build:embed"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "eslint": "^8.57.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.1.1"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "idiomorph": "^0.7.4"
  }
}
