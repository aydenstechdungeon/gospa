{
  "name": "@gospa/client",
  "version": "0.1.14",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    },
    "./runtime-secure": {
      "import": "./dist/runtime-secure.js",
      "types": "./dist/runtime-secure.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "bun typecheck",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "rm dist/*.js && bun build ./src/runtime.ts ./src/runtime-secure.ts ./src/runtime-simple.ts ./src/runtime-core.ts ./src/runtime-micro.ts --outdir ./dist --target browser --minify --splitting --format esm",
    "build:embed": "bun run build && cp -r ./dist/* ../embed/",
    "build:empty": "rm -r ../embed/*.js && bun run build:embed"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "typescript": "^5.3.3",
    "prettier": "^3.2.5",
    "eslint": "^8.57.0",
    "typescript-eslint": "^7.1.1"
  },
  "optionalDependencies": {
    "dompurify": "^3.3.1"
  },
  "peerDependenciesMeta": {
    "dompurify": {
      "optional": true
    }
  }
}